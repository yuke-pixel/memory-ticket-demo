<view class="page home-page">
  <view class="prompt-wrap">
    <text class="prompt">你想留下什么回忆？</text>
    <text class="brand-mark">✦ ︶ ︶ ︶</text>
  </view>

  <view class="choice-list">
    <button class="choice paper-card" data-scene="毕业" bindtap="chooseScene">
      <text class="choice-icon blue">🎓</text>
      <text class="choice-title">毕业</text>
    </button>
    <button class="choice paper-card" data-scene="旅行" bindtap="chooseScene">
      <text class="choice-icon tan">🧳</text>
      <text class="choice-title">旅行</text>
    </button>
    <button class="choice paper-card" data-scene="一个重要的人" bindtap="chooseScene">
      <text class="choice-icon gray">👥</text>
      <text class="choice-title">一个重要的人</text>
    </button>
  </view>

  <view class="bottom-wave">⌁</view>
</view>
