.home-page {
  position: relative;
  min-height: 100vh;
  padding-top: 86rpx;
  padding-left: 28rpx;
  padding-right: 18rpx;
  overflow: hidden;
}

.decor {
  position: absolute;
  z-index: 0;
  color: rgba(213, 169, 79, 0.72);
  pointer-events: none;
}

.decor-left {
  left: 54rpx;
  top: 126rpx;
  font-size: 34rpx;
}

.decor-right {
  right: 42rpx;
  top: 156rpx;
  color: rgba(93, 145, 173, 0.58);
  font-size: 30rpx;
  letter-spacing: 8rpx;
}

.prompt-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-title {
  display: block;
  color: #2b2924;
  font-size: 46rpx;
  line-height: 1;
  letter-spacing: 2rpx;
}

.prompt {
  display: block;
  margin-top: 24rpx;
  color: #2b2924;
  font-size: 34rpx;
  line-height: 1;
  white-space: nowrap;
}

.brand-mark {
  display: block;
  margin-top: 22rpx;
  color: #e4bd62;
  font-size: 34rpx;
}

.memory-line {
  margin-top: 36rpx;
  text-align: center;
}

.memory-title {
  display: block;
  color: #756c60;
  font-size: 26rpx;
  line-height: 1;
  white-space: nowrap;
}

.memory-meta {
  display: block;
  margin-top: 22rpx;
  color: #5d91ad;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.choice-list {
  margin-top: 52rpx;
  margin-left: -233rpx;
  margin-right: -233rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.choice {
  position: relative;
  height: 142rpx;
  padding: 0 233rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 26rpx;
  border-radius: 18rpx;
  box-shadow: 0 18rpx 34rpx rgba(83, 70, 54, 0.1);
}

.choice::after {
  content: "";
  position: absolute;
  top: 20rpx;
  right: 164rpx;
  bottom: 20rpx;
  border-left: 1rpx dashed rgba(138, 129, 114, 0.22);
}

.choice-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 50rpx;
  flex-shrink: 0;
}

.choice-icon.blue {
  background: #dcebf1;
}

.choice-icon.tan {
  background: #efe1cf;
}

.choice-icon.gray {
  background: #e8e3dc;
}

.choice-icon.soft {
  background: #eef1e7;
  color: #7f8f72;
}

.choice-title {
  display: block;
  color: #2b2924;
  font-size: 30rpx;
  line-height: 1;
  white-space: nowrap;
}

.choice-text {
  position: relative;
  z-index: 1;
  width: 360rpx;
  flex: 0 0 360rpx;
}

.choice-desc {
  display: block;
  margin-top: 16rpx;
  color: #8a8172;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.paper-trim {
  margin: 34rpx auto 0;
  width: 190rpx;
  display: flex;
  justify-content: space-between;
}

.paper-trim text {
  width: 34rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(143, 178, 196, 0.5);
}

.bottom-wave {
  margin-top: 22rpx;
  color: #8fb2c4;
  text-align: center;
  font-size: 34rpx;
}
