.home-page {
  min-height: 100vh;
  padding-top: 86rpx;
  padding-left: 28rpx;
  padding-right: 18rpx;
}

.prompt-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-title {
  display: block;
  color: #2b2924;
  font-size: 46rpx;
  line-height: 1;
  letter-spacing: 2rpx;
}

.prompt {
  display: block;
  margin-top: 24rpx;
  color: #2b2924;
  font-size: 34rpx;
  line-height: 1;
  white-space: nowrap;
}

.brand-mark {
  display: block;
  margin-top: 22rpx;
  color: #e4bd62;
  font-size: 34rpx;
}

.memory-line {
  margin-top: 36rpx;
  text-align: center;
}

.memory-title {
  display: block;
  color: #756c60;
  font-size: 26rpx;
  line-height: 1;
  white-space: nowrap;
}

.memory-meta {
  display: block;
  margin-top: 22rpx;
  color: #5d91ad;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.choice-list {
  margin-top: 52rpx;
  margin-left: -83rpx;
  margin-right: -83rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.choice {
  height: 142rpx;
  padding: 0 52rpx 0 34rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  border-radius: 18rpx;
  box-shadow: 0 18rpx 34rpx rgba(83, 70, 54, 0.1);
}

.choice-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 50rpx;
  flex-shrink: 0;
}

.choice-icon.blue {
  background: #dcebf1;
}

.choice-icon.tan {
  background: #efe1cf;
}

.choice-icon.gray {
  background: #e8e3dc;
}

.choice-icon.soft {
  background: #f3eadf;
  color: #d5a94f;
}

.choice-title {
  display: block;
  color: #2b2924;
  font-size: 30rpx;
  line-height: 1;
  white-space: nowrap;
}

.choice-text {
  flex: 1;
  min-width: 0;
}

.choice-desc {
  display: block;
  margin-top: 16rpx;
  color: #8a8172;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.bottom-wave {
  margin-top: 38rpx;
  color: #8fb2c4;
  text-align: center;
  font-size: 34rpx;
}
