.home-page {
  min-height: 100vh;
  padding: 40rpx 34rpx 44rpx;
  background: #f9f5ee;
  overflow: hidden;
}

.top-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.top-brand {
  color: #1f2a33;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.top-subtitle {
  color: #8a8172;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.hero-title-block {
  margin-top: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-title {
  display: block;
  color: #1f2a33;
  font-size: 48rpx;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
}

.prompt {
  display: block;
  margin-top: 10rpx;
  color: #7f8b96;
  font-size: 23rpx;
  line-height: 1;
  white-space: nowrap;
}

.hero-mark {
  display: block;
  margin-top: 20rpx;
  color: #d5a94f;
  font-size: 26rpx;
  line-height: 1;
  letter-spacing: 6rpx;
}

.home-photo {
  display: block;
  width: 100%;
  height: 328rpx;
  margin-top: 32rpx;
  border-radius: 28rpx;
  background: #efe4d7;
  box-shadow: 0 18rpx 36rpx rgba(83, 70, 54, 0.1);
}

.intro-copy {
  margin-top: 34rpx;
}

.eyebrow {
  display: block;
  color: #d85f4f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.intro-title {
  display: block;
  margin-top: 20rpx;
  color: #1f2a33;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.intro-desc {
  display: block;
  width: 660rpx;
  margin-top: 18rpx;
  color: #718192;
  font-size: 28rpx;
  line-height: 1.65;
}

.choice-list {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.choice {
  width: 100%;
  min-height: 132rpx;
  padding: 28rpx 30rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border: 1rpx solid #dfd2bf;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 30rpx rgba(83, 70, 54, 0.07);
}

.choice:first-child {
  border-color: #e69082;
  background: rgba(255, 251, 247, 0.88);
}

.choice-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 38rpx;
  flex-shrink: 0;
}

.choice-icon.tan {
  background: #efe1cf;
}

.choice-icon.blue {
  background: #dcebf1;
}

.choice-icon.gray {
  background: #e8e3dc;
}

.choice-icon.soft {
  background: #eef1e7;
  color: #7f8f72;
}

.choice-text {
  flex: 1;
  min-width: 0;
}

.choice-title {
  display: block;
  color: #14191f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.choice-desc {
  display: block;
  margin-top: 18rpx;
  color: #718192;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
}
