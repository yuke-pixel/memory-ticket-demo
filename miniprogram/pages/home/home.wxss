.home-page {
  min-height: 100vh;
  padding: 56rpx 24rpx 44rpx;
  background: #f9f5ee;
  overflow-x: hidden;
}

.custom-nav {
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-circle {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dfd2bf;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  color: #1f2a33;
  font-size: 24rpx;
}

.nav-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-brand {
  color: #1f2a33;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
}

.nav-subtitle {
  margin-top: 12rpx;
  color: #8a8172;
  font-size: 20rpx;
  line-height: 1.25;
  white-space: nowrap;
}

.home-photo {
  display: block;
  width: 100%;
  height: 336rpx;
  margin-top: 28rpx;
  border-radius: 28rpx;
  background: #efe4d7;
  box-shadow: 0 18rpx 36rpx rgba(83, 70, 54, 0.1);
}

.intro-copy {
  margin-top: 34rpx;
  padding: 0 2rpx;
}

.eyebrow {
  display: block;
  color: #d85f4f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.intro-title {
  display: block;
  margin-top: 20rpx;
  color: #1f2a33;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.intro-desc {
  display: block;
  width: 100%;
  margin-top: 18rpx;
  color: #718192;
  font-size: 28rpx;
  line-height: 1.65;
}

.trust-row {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.trust-row text {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dfd2bf;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #3c7896;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.choice-list {
  margin-top: 28rpx;
  margin-left: -18rpx;
  margin-right: -18rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.choice {
  width: 100%;
  margin: 0;
  min-height: 152rpx;
  padding: 26rpx 30rpx 26rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 24rpx;
  text-align: left;
  border: 1rpx solid #dfd2bf;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 30rpx rgba(83, 70, 54, 0.07);
}

.choice:first-child {
  border-color: #e69082;
  background: rgba(255, 251, 247, 0.88);
}

.choice-icon {
  width: 102rpx;
  height: 102rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 50rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.choice-icon.tan {
  background: #efe1cf;
}

.choice-icon.blue {
  background: #dcebf1;
}

.choice-icon.gray {
  background: #e8e3dc;
}

.choice-icon.soft {
  background: #eef1e7;
  color: #7f8f72;
}

.choice-thumb {
  width: 100%;
  height: 100%;
}

.choice-text {
  flex: 1;
  min-width: 0;
  text-align: left;
}

.choice-title {
  display: block;
  color: #14191f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.choice-desc {
  display: block;
  margin-top: 18rpx;
  color: #718192;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
