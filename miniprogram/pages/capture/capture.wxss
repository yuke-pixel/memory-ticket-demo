.page-head {
  position: relative;
  text-align: center;
}

.scene-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 44rpx;
  margin: 0 auto 18rpx;
  border: 1rpx solid #dfd2bf;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #756c60;
  font-size: 22rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  color: #2b2924;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.mark {
  position: absolute;
  right: 60rpx;
  top: 8rpx;
  color: #e4bd62;
  font-size: 30rpx;
}

.memory-types {
  margin-top: 28rpx;
  display: flex;
  gap: 14rpx;
}

.memory-types text {
  flex: 1;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(143, 178, 196, 0.35);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #5d91ad;
  font-size: 21rpx;
  font-weight: 700;
}

.media-box {
  margin-top: 22rpx;
  height: 232rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-style: dashed;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.plus {
  color: #2b2924;
  font-size: 36rpx;
}

.add-copy {
  margin-top: 16rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.asset-row {
  display: none;
}

.asset-chip {
  flex: 1;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dfd2bf;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #8a8172;
  font-size: 22rpx;
  font-weight: 700;
}

.asset-chip.active {
  background: #efe4d7;
  color: #2b2924;
}

.form-card {
  margin-top: 24rpx;
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 12rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.field input,
.field textarea {
  width: 100%;
  border: 1rpx solid #dfd2bf;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #2b2924;
  font-size: 26rpx;
}

.field input {
  height: 72rpx;
  padding: 0 22rpx;
}

.field textarea {
  height: 132rpx;
  padding: 20rpx 22rpx;
}

.record-area {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wave-line {
  color: #8fb2c4;
  font-size: 30rpx;
}

.record-time {
  color: #8a8172;
  font-size: 22rpx;
}

.record-btn {
  margin-top: 12rpx;
  width: 132rpx;
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 12rpx solid #e8ded0;
  border-radius: 50%;
  background: #5d91ad;
  color: #fff;
  font-size: 52rpx;
  box-shadow: 0 14rpx 30rpx rgba(69, 117, 142, 0.3);
}

.record-btn.recording {
  background: #b65f4a;
}

.record-hint {
  margin-top: 16rpx;
  color: #2b2924;
  font-size: 24rpx;
}

.primary-btn {
  margin-top: 34rpx;
}
