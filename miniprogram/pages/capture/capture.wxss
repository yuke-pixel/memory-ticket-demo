.capture-page {
  min-height: 100vh;
  padding: 40rpx 32rpx 48rpx;
  background: #f9f5ee;
}

.mini-nav {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.mini-nav text:first-child {
  color: #1f2a33;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.mini-nav text:last-child {
  color: #8a8172;
  font-size: 22rpx;
  line-height: 1;
}

.page-head {
  margin-top: 48rpx;
}

.eyebrow {
  display: block;
  color: #d85f4f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1rpx;
}

.title {
  display: block;
  margin-top: 20rpx;
  color: #1f2a33;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.1;
}

.subtitle {
  display: block;
  width: 650rpx;
  margin-top: 18rpx;
  color: #756c60;
  font-size: 28rpx;
  line-height: 1.65;
}

.input-tabs {
  height: 76rpx;
  margin-top: 28rpx;
  padding: 6rpx;
  display: flex;
  border: 1rpx solid #dfd2bf;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
}

.input-tabs button {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: #8a8172;
  font-size: 24rpx;
  font-weight: 800;
}

.input-tabs button.active {
  background: #2b2924;
  color: #fff;
}

.collect-card {
  margin-top: 22rpx;
  padding: 26rpx;
  display: flex;
  gap: 24rpx;
  border-radius: 28rpx;
}

.media-thumb {
  position: relative;
  width: 252rpx;
  height: 210rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #efe4d7;
  flex-shrink: 0;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.media-status {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(43, 41, 36, 0.9);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
}

.meta-fields {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 12rpx;
  color: #8a8172;
  font-size: 22rpx;
  line-height: 1;
}

.field input,
.text-panel textarea,
.interview-answer {
  width: 100%;
  border: 1rpx solid #dfd2bf;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #2b2924;
  font-size: 28rpx;
}

.field input {
  height: 76rpx;
  padding: 0 22rpx;
}

.text-panel,
.voice-panel {
  width: 100%;
}

.panel-question {
  display: block;
  color: #1f2a33;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.text-panel textarea {
  height: 214rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  line-height: 1.55;
}

.voice-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.voice-copy {
  display: block;
  width: 560rpx;
  margin-top: 16rpx;
  color: #756c60;
  font-size: 24rpx;
  line-height: 1.6;
}

.record-btn {
  margin-top: 24rpx;
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 12rpx solid #efe4d7;
  border-radius: 50%;
  background: #b65f4a;
  color: #fff;
  font-size: 34rpx;
  box-shadow: 0 14rpx 30rpx rgba(182, 95, 74, 0.22);
}

.record-btn.recording {
  background: #2b2924;
}

.record-time {
  display: block;
  margin-top: 14rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.ai-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.ai-card.disabled {
  opacity: 0.78;
}

.ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.ai-badge {
  width: 138rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #dfeeda;
  color: #5e7f51;
  font-size: 22rpx;
  font-weight: 900;
}

.ai-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.toggle-btn {
  width: 86rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #e8ded0;
  color: #756c60;
  font-size: 22rpx;
  font-weight: 900;
}

.toggle-btn.on {
  background: #2b2924;
  color: #fff;
}

.interview-question {
  display: block;
  margin-top: 26rpx;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  background: #eef6ef;
  color: #1f2a33;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.interview-answer {
  height: 178rpx;
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  line-height: 1.55;
}

.audio-strip {
  width: 100%;
  min-height: 106rpx;
  margin-top: 20rpx;
  padding: 22rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 24rpx;
  background: #f3eee7;
  text-align: left;
}

.audio-dot {
  width: 52rpx;
  height: 52rpx;
  border: 16rpx solid #b65f4a;
  border-radius: 50%;
  background: #fff;
  flex-shrink: 0;
}

.audio-dot.recording {
  border-color: #2b2924;
}

.audio-title {
  display: block;
  color: #2b2924;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.audio-note {
  display: block;
  margin-top: 12rpx;
  color: #8a8172;
  font-size: 22rpx;
}

.primary-btn {
  margin-top: 30rpx;
  border-radius: 24rpx;
}
