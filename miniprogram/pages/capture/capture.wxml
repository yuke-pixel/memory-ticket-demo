<view class="page capture-page">
  <view class="capture-nav">
    <view class="back-button" role="button" bindtap="goBack">‹</view>
    <text class="nav-heading">记录碎碎念</text>
    <view class="nav-safe-space"></view>
  </view>

  <view class="capture-intro">
    <view class="scene-pill">{{sceneProfile.icon}}<text>{{scene}}</text></view>
    <text class="intro-title">{{sceneProfile.captureTitle}}</text>
    <text class="intro-subtitle">{{sceneProfile.captureSubtitle}}</text>
    <text class="intro-star">✦</text>
    <text class="intro-line">﹏ · ﹏</text>
  </view>

  <view class="capture-workspace">
    <view class="mode-tabs">
      <view class="mode-tab {{activeMode === 'media' ? 'active' : ''}}" role="button" data-mode="media" bindtap="selectMode">
        <text class="mode-icon">▣</text>
        <text>照片 / 视频</text>
      </view>
      <view class="mode-tab {{activeMode === 'text' ? 'active' : ''}}" role="button" data-mode="text" bindtap="selectMode">
        <text class="mode-icon">✎</text>
        <text>文字</text>
      </view>
      <view class="mode-tab {{activeMode === 'voice' ? 'active' : ''}}" role="button" data-mode="voice" bindtap="selectMode">
        <text class="mode-icon">≡</text>
        <text>声音</text>
      </view>
      <view class="mode-tab {{activeMode === 'list' ? 'active' : ''}}" role="button" data-mode="list" bindtap="selectMode">
        <text class="mode-icon">☷</text>
        <text>清单</text>
      </view>
    </view>

    <view wx:if="{{activeMode === 'media'}}" class="media-box" role="button" bindtap="chooseMedia">
      <block wx:if="{{mediaType === 'video' && mediaPath}}">
        <video class="media-preview" src="{{mediaPath}}" controls></video>
      </block>
      <block wx:elif="{{mediaPath}}">
        <image class="media-preview" src="{{mediaPath}}" mode="aspectFill" />
      </block>
      <block wx:else>
        <image class="empty-media-image" src="/assets/home-keepsake.jpg" mode="aspectFill" />
        <view class="media-overlay">
          <view class="add-circle">＋</view>
          <text class="add-title">添加照片 / 视频</text>
          <text class="add-subtitle">{{sceneProfile.mediaHint}}</text>
        </view>
      </block>
    </view>

    <view wx:elif="{{activeMode === 'text'}}" class="focus-panel text-focus-panel">
      <text class="focus-kicker">写下这一刻</text>
      <textarea class="focus-textarea" value="{{text}}" maxlength="1200" bindinput="onTextInput" placeholder="{{sceneProfile.textPlaceholder}}" />
      <text class="focus-count">{{text.length || 0}} / 1200</text>
    </view>

    <view wx:elif="{{activeMode === 'voice'}}" class="focus-panel voice-focus-panel">
      <text class="voice-wave">│·││·│·││·│·│││·│</text>
      <text class="voice-panel-time">{{recordText}}</text>
      <view class="voice-panel-button {{recording ? 'recording' : ''}}" role="button" bindtouchstart="startRecord" bindtouchend="stopRecord" bindtouchcancel="stopRecord">
        <text>♫</text>
        <text>{{recording ? '松开保存' : '按住开始讲'}}</text>
      </view>
    </view>

    <view wx:else class="focus-panel checklist-panel">
      <text class="focus-kicker">这段记忆里有什么？</text>
      <view class="check-item {{item.done ? 'done' : ''}}" wx:for="{{checklist}}" wx:key="key" role="checkbox" data-index="{{index}}" bindtap="toggleCheckItem">
        <view class="check-box">{{item.done ? '✓' : ''}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <view class="details-card">
      <view class="field-block">
        <view class="field-label"><text class="field-icon">▣</text><text>日期（可选）</text></view>
        <picker mode="date" value="{{datePickerValue}}" bindchange="onDateChange">
          <view class="picker-field"><text>{{date}}</text><text class="chevron">›</text></view>
        </picker>
      </view>

      <view class="field-block">
        <view class="field-label"><text class="field-icon">◉</text><text>地点（可选）</text></view>
        <view class="input-shell">
          <input value="{{location}}" maxlength="60" bindinput="onLocationInput" placeholder="{{sceneProfile.defaultLocation}}" />
          <text class="chevron">›</text>
        </view>
      </view>

      <view class="field-block">
        <view class="field-label"><text class="field-icon">♡</text><text>{{sceneProfile.question}}</text></view>
        <view class="textarea-shell">
          <textarea value="{{text}}" maxlength="200" bindinput="onTextInput" placeholder="{{sceneProfile.textPlaceholder}}" />
          <text class="textarea-count">{{text.length || 0}} / 200</text>
        </view>
      </view>

      <view class="ai-row">
        <view class="ai-copy">
          <view class="ai-title"><text>✦</text><text>AI 轻访谈</text></view>
          <text class="ai-desc">{{aiInterview ? '根据你的线索，每次只问一个问题' : '已关闭，只保存你主动记录的内容'}}</text>
        </view>
        <switch checked="{{aiInterview}}" color="#5d91ad" bindchange="toggleAiInterview" />
      </view>
    </view>
  </view>

  <view class="record-area">
    <text class="wave-line">·│·││·│·││·</text>
    <text class="record-time">{{recordText}}</text>
    <view class="record-pill {{recording ? 'recording' : ''}}" role="button" bindtouchstart="startRecord" bindtouchend="stopRecord" bindtouchcancel="stopRecord">
      <text class="record-icon">♫</text>
      <text>{{recording ? '松开保存声音' : '按住录制声音'}}</text>
    </view>
  </view>

  <view class="generate-button" role="button" bindtap="goPreview">
    <text class="generate-title">✦ 生成累积</text>
    <text class="generate-subtitle">{{sceneProfile.saveSubtitle}}</text>
  </view>
</view>
