<view class="page capture-page">
  <view class="page-head">
    <view class="scene-pill">{{sceneProfile.icon}} {{scene}}</view>
    <text class="title">{{sceneProfile.captureTitle}}</text>
    <text class="subtitle">{{sceneProfile.captureSubtitle}}</text>
    <text class="mark">✦</text>
  </view>

  <view class="memory-types">
    <text>照片 / 视频</text>
    <text>文字</text>
    <text>原声</text>
  </view>

  <button class="media-box paper-card" bindtap="chooseMedia">
    <block wx:if="{{mediaType === 'video'}}">
      <video class="media-preview" src="{{mediaPath}}" controls></video>
    </block>
    <block wx:elif="{{mediaPath}}">
      <image class="media-preview" src="{{mediaPath}}" mode="aspectFill" />
    </block>
    <block wx:else>
      <image class="empty-media-image" src="/assets/home-keepsake.jpg" mode="aspectFill" />
      <text class="plus">＋</text>
      <text class="add-copy">添加照片 / 视频</text>
    </block>
  </button>

  <view class="form-card paper-card">
    <view class="field">
      <text>日期（可选）</text>
      <input value="{{date}}" bindinput="onDateInput" placeholder="{{sceneProfile.defaultDate}}" />
    </view>
    <view class="field">
      <text>地点（可选）</text>
      <input value="{{location}}" bindinput="onLocationInput" placeholder="{{sceneProfile.defaultLocation}}" />
    </view>
    <view class="field">
      <text>{{sceneProfile.question}}</text>
      <textarea value="{{text}}" bindinput="onTextInput" placeholder="{{sceneProfile.textPlaceholder}}" />
    </view>
  </view>

  <view class="record-area">
    <text class="wave-line">︶ ︶ ︶</text>
    <text class="record-time">{{recordText}}</text>
    <button class="record-btn {{recording ? 'recording' : ''}}" bindtap="toggleRecord">🎙</button>
    <text class="record-hint">按住这段声音</text>
  </view>

  <button class="primary-btn" bindtap="goPreview">生成票根</button>
</view>
