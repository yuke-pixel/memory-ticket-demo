<view class="page preview-page">
  <view class="nav-row">
    <view>
      <text class="nav-title">设计你的票根</text>
    </view>
    <button bindtap="goStory">预览</button>
  </view>

  <view class="section-label">正面票根</view>
  <view class="ticket ticket-bg">
    <image class="ticket-art" src="/assets/seaside-train-ticket.png" mode="aspectFill" />
    <view class="ticket-info">
      <text class="brand">记忆票根  MEMORY TICKET</text>
      <text class="ticket-title">{{memory.title}}</text>
      <text class="ticket-date">日期\n{{memory.date}}</text>
      <text class="ticket-place">地点\n{{memory.location}}</text>
      <view class="qr"></view>
      <text class="scan-copy">扫码回到那一天</text>
    </view>
  </view>

  <view class="section-label">背面预览</view>
  <view class="back-card paper-card">
    <text class="back-title">给未来的自己</text>
    <text class="back-copy">{{shortText}}</text>
    <view class="qr small"></view>
  </view>

  <view class="section-label">换一种票面</view>
  <view class="template-row">
    <button class="template active">火车票</button>
    <button class="template">登机牌</button>
    <button class="template">校园卡</button>
    <button class="template">明信片</button>
  </view>

  <button class="primary-btn" bindtap="goStory">查看扫码故事页</button>
</view>
