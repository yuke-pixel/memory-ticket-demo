<view class="page archive-page">
  <view class="page-head">
    <view>
      <text class="title">我的票根</text>
      <text class="subtitle">每一张票，都是一段记忆</text>
    </view>
    <button class="add-btn" bindtap="createNew">＋</button>
  </view>

  <view class="ticket-stack">
    <view
      wx:for="{{memories}}"
      wx:key="id"
      class="archive-ticket ticket-bg"
      data-id="{{item.id}}"
      bindtap="openStory"
    >
      <image class="ticket-art" src="{{item.backgroundPath}}" mode="aspectFill" />
      <view class="ticket-content">
        <text class="ticket-kicker">{{item.scene}} · {{item.templateName}}</text>
        <text class="ticket-title">{{item.title}}</text>
        <text class="ticket-meta">{{item.date || '日期待补充'}} · {{item.location || '地点待补充'}}</text>
        <view class="progress-line">
          <view class="progress-bar" style="width: {{item.progressPercent}}%;"></view>
        </view>
        <text class="ticket-progress">{{item.progress}}</text>
      </view>
      <view class="ticket-actions">
        <button catchtap="editMemory" data-id="{{item.id}}">编辑</button>
        <view wx:if="{{item.template === 'train' || item.template === 'boarding'}}" class="nfc">NFC</view>
        <view wx:else class="qr-mini"></view>
      </view>
    </view>
  </view>
</view>
