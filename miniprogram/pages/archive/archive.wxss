.page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.title {
  display: block;
  font-size: 42rpx;
  color: #2b2924;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  color: #8a8172;
  font-size: 24rpx;
}

.add-btn {
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid #dfd2bf;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #2b2924;
  font-size: 36rpx;
}

.ticket-stack {
  margin-top: 38rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.archive-ticket {
  position: relative;
  min-height: 202rpx;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid #dfd2bf;
  border-radius: 18rpx;
  box-shadow: 0 14rpx 28rpx rgba(83, 70, 54, 0.1);
}

.archive-ticket::before {
  content: "";
  position: absolute;
  left: -12rpx;
  top: 28rpx;
  bottom: 28rpx;
  width: 24rpx;
  border-radius: 999rpx;
  background: #f9f5ee;
  box-shadow: 0 44rpx 0 #f9f5ee, 0 88rpx 0 #f9f5ee;
}

.archive-ticket::after {
  content: "";
  position: absolute;
  top: 0;
  right: 120rpx;
  bottom: 0;
  border-left: 2rpx dashed rgba(138, 129, 114, 0.45);
}

.light-ticket {
  background: linear-gradient(135deg, #fbf6ee, #e9eef0);
}

.sepia-ticket {
  background: linear-gradient(135deg, #fbf3e5, #e6d6bf);
}

.ticket-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  max-width: 470rpx;
}

.ticket-kicker {
  color: #5d91ad;
  font-size: 20rpx;
  font-weight: 800;
  text-transform: uppercase;
}

.ticket-title {
  font-size: 32rpx;
  color: #2b2924;
}

.ticket-meta,
.ticket-progress {
  font-size: 22rpx;
  color: #756c60;
}

.ticket-progress {
  color: #3c7896;
}

.progress-line {
  width: 220rpx;
  height: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(138, 129, 114, 0.18);
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #8fb2c4;
}

.ticket-actions {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 86rpx;
}

.ticket-actions button {
  width: 78rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #2b2924;
  font-size: 20rpx;
}

.nfc {
  position: absolute;
  right: 30rpx;
  bottom: 34rpx;
  color: #2b2924;
  font-size: 20rpx;
}

.qr-mini {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  width: 58rpx;
  height: 58rpx;
  border: 6rpx solid #fff;
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, #2b2924 10rpx, transparent 0) 0 0 / 20rpx 20rpx,
    linear-gradient(#2b2924 10rpx, transparent 0) 0 0 / 20rpx 20rpx,
    #f7f2e9;
}
